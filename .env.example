POSTGRES_PASSWORD=change-me
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=change-me
LLM_MODEL=gpt-5
ASR_BASE_URL=
ASR_API_KEY=
ASR_MODEL=whisper-1
TELEGRAM_TOKEN=
DEFAULT_USER_ID=demo-user

# Optional email delivery for daily reports. Keep SMTP_PASSWORD secret and do
# not commit real credentials.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=

# Optional video authorization. Prefer an exported cookies file mounted by
# docker-compose.prod.yml as ./secrets:/run/codo-secrets:ro.
YTDLP_COOKIES_FILE=/run/codo-secrets/yt-dlp.cookies.txt
YTDLP_COOKIES_FROM_BROWSER=chromium:/run/codo-browser-profile/chromium
YTDLP_USER_AGENT=
YTDLP_REFERER=
